# ==========================================================================
# Polyglot-Attest monorepo — root .gitignore
# ==========================================================================
# Defense-in-depth: per-subproject .gitignore files also exist in
# contracts/, gateway/, hospital-mockup/, services/modal/. Removing any
# single file still leaves the repo safe. If a new rule is needed, prefer
# adding it here and mirroring to the relevant subdir when risk is project-
# specific.
# --------------------------------------------------------------------------


# ── SECRETS · the line between dev and public ─────────────────────────────
# Anything matching .env is ignored, except the opt-in template files.
# The explicit allow list at the bottom prevents "I ran `git add .` and
# committed a backup of .env" disasters.
.env
.env.*
!.env.example
!.env.sample
!.env.template

# Cryptographic material — private keys, wallets, keystores, certs.
# Error on the side of paranoia: any file suggesting a secret blob is out.
*.pem
*.key
*.p12
*.pfx
*.asc
*.gpg
*.keystore
keystore/
keystores/
wallet.json
wallets.json
secrets/
.secrets/

# Modal / HuggingFace / cloud-provider local state. These may persist tokens.
.modal/
.huggingface/
.aws/
.gcloud/
.kube/

# Foundry broadcast artifacts contain deployer addresses and per-tx metadata
# for real deployments. Safe on a throwaway testnet, risky in mainnet diffs.
# Ignore by default; commit per-network snapshots deliberately if needed.
broadcast/
**/broadcast/


# ── BUILD ARTIFACTS ──────────────────────────────────────────────────────
# Foundry
out/
cache/
cache_forge/
forge-cache/
*.tsbuildinfo

# TypeScript build info + Vite output
dist/
build/
.vite/
.next/
.nuxt/
.svelte-kit/
.output/
.turbo/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyre/
.pytype/
.coverage
coverage.xml
htmlcov/

# Node
node_modules/


# ── DEPENDENCY DIRECTORIES ───────────────────────────────────────────────
# Foundry installs submodules under lib/; those are committed as submodules
# or re-fetched, not checked in directly. Same pattern applies across the
# repo.
/contracts/lib/
**/vendor/


# ── VIRTUAL ENVIRONMENTS ─────────────────────────────────────────────────
.venv/
venv/
env/
.virtualenv/
.Python


# ── LOGS ─────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# ── OS / FILE-SYSTEM CRUFT ───────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/


# ── EDITOR / IDE ─────────────────────────────────────────────────────────
.idea/
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json.example
*.swp
*.swo
*~
.fleet/
.nova/
.history/


# ── CLAUDE / AI ASSISTANT LOCAL STATE ────────────────────────────────────
.claude/settings.local.json
.claude/*.local.md


# ── BACKUP / SCRATCH ─────────────────────────────────────────────────────
*.bak
*.orig
*.tmp
*.temp
*.old
*~.md
.~*


# ── PACKAGING / DISTRIBUTION ─────────────────────────────────────────────
*.tar
*.tar.gz
*.zip
*.7z
*.rar


# ── DATABASE FILES (local dev) ───────────────────────────────────────────
*.sqlite
*.sqlite3
*.db
*.db-journal
.vercel
